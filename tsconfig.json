{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  // Production source directories.
  // Tests are excluded (vitest has its own TS handling).
  // Dashboard has its own build via vite (see apps/dashboard/vite.config.ts).
  "include": ["apps", "src", "packages"],
  "exclude": ["node_modules", "dist", "test", "apps/dashboard/app"]
}
