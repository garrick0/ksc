{
  "name": "ksc-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.16.1",
  "description": "Architectural enforcement for TypeScript through the type system",
  "scripts": {
    "build": "pnpm -r --filter './apps/*' --filter './libs/*' --filter './libs/languages/*' --filter './libs/analyses/*' run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "codegen": "tsx apps/cli/bin.ts codegen"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.1",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.2.0"
  }
}
