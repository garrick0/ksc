{
  "name": "kindscript",
  "version": "0.1.0",
  "description": "Architectural enforcement for TypeScript through the type system",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ksc": "dist/cli/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "dashboard:dev": "vite --config vite.config.dashboard.ts",
    "dashboard:build": "vite build --config vite.config.dashboard.ts",
    "showcase": "tsx examples/showcase.ts",
    "showcase:fixed": "tsx examples/showcase.ts --mode=fixed",
    "showcase:live": "tsx examples/showcase.ts --mode=live"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.1",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "elkjs": "^0.9.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
